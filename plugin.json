{
    "name": "mat-preview",
    "version": "1.1.0",
    "type": "convert",
    "roles": [
        "viewer"
    ],
    "entry": "entry.ps1",
    "args": [
        "-i",
        "${input_file}",
        "-o",
        "${output_file}.html"
    ],
    "formats": [
        "mat",
        "fig"
    ],
    "appMinVersion": "4.1.3",
    "author": "you",
    "description": "Preview MATLAB .mat and .fig files as lightweight Workspace-style HTML.",
    "releaseDate": "2026-05-16"
}
